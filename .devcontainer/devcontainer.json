{
  "name": "Monolith Dev Env",

  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/itsmechlark/features/postgresql:1": {
      "version": "15"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": "false"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres@localhost:5432/postgres",
    "FLASK_APP": "backend/run.py",
    "FLASK_DEBUG": "1",
    "NODE_ENV": "development",
    "VITE_API_URL": "http://localhost:5000",
    "BASE_URL": "http://localhost:5173",
    "API_URL": "http://localhost:5000",
    "LOGTO_CLIENT_ID": "tav5btfloqrfq3l6u7hsg",
    "LOGTO_CLIENT_SECRET": "Q4Ud5gKHzkNm3KUoAB8ZmdVgroT9pALS",
    "LOGTO_ISSUER": "https://3jocgf.logto.app/oidc",
    "LOGTO_REDIRECT_URI": "http://localhost:5000/auth/callback",
    "SESSION_SECRET": "4ae28ee12d16ee3be4b70b222bc3222d66fb0c68f24a144b91010015e40b01bc",
    "SECRET_KEY": "35bcf4c79690000d26b51d7b7154994af728b8245402246ba65d677453e310fe",
    "YOOKASSA_SHOP_ID": "1321996",
    "YOOKASSA_SECRET_KEY": "test_bac_Z9MoZ-hN2mgQQcwBHo6TTJbY_vyQhsIuwJxBiZg",
    "CALCOM_API_KEY": "cal_live_3165bcb34af2e318e3982ff9e92554c3",
    "CALCOM_EVENT_TYPE_SLUG": "newsession",
    "CALCOM_API_URL": "https://api.cal.com/v2",
    "CALCOM_WEBHOOK_SECRET": "48WlNGt8VRNpctXbPvvLvw"
  },
  "postCreateCommand": "chmod +x ./.devcontainer/welcome.sh && npm install --prefix frontend && pip install -r backend/requirements.txt && echo './.devcontainer/welcome.sh' >> ~/.bashrc",

  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[vue]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "sqltools.connections": [
          {
            "ssh": "Disabled",
            "previewLimit": 50,
            "server": "localhost",
            "port": 5432,
            "driver": "PostgreSQL",
            "name": "Dev Server",
            "database": "postgres",
            "username": "postgres",
            "password": ""
          }
        ]
      },
      "extensions": [
        "-ms-ossdata.vscode-pgsql",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "christian-kohler.path-intellisense",
        "Vue.volar",
        "bradlc.vscode-tailwindcss",
        "stivo.tailwind-fold"
      ]
    }
  },

  "forwardPorts": [5173, 5000, 5432],
  "portsAttributes": {
    "5173": { "label": "Vite Frontend", "onAutoForward": "notify" },
    "5000": { "label": "Flask Backend", "onAutoForward": "notify" },
    "5432": { "label": "Postgres Server", "onAutoForward": "silent" }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }
}
